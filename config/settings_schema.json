[
  {
    "name": "theme_info",
    "theme_name": "Hasna's Coffee",
    "theme_version": "1.0.0",
    "theme_author": "Hasna's Coffee",
    "theme_documentation_url": "https://hasnascoffee.com",
    "theme_support_url": "https://hasnascoffee.com"
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "Will be scaled down to 32×32px"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_bg",
        "label": "Background",
        "default": "#0F0B07"
      },
      {
        "type": "color",
        "id": "color_bg_alt",
        "label": "Background (alternate)",
        "default": "#1A1008"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text",
        "default": "#F5EDD6"
      },
      {
        "type": "color",
        "id": "color_text_muted",
        "label": "Text (muted)",
        "default": "#A89880"
      },
      {
        "type": "color",
        "id": "color_gold",
        "label": "Accent (Gold)",
        "default": "#C8902A"
      },
      {
        "type": "color",
        "id": "color_gold_light",
        "label": "Accent (Gold Light)",
        "default": "#E8B84B"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "playfair_display_n4"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "inter_n4"
      },
      {
        "type": "range",
        "id": "font_body_size",
        "label": "Body text size",
        "min": 14,
        "max": 18,
        "step": 1,
        "unit": "px",
        "default": 16
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "page", "label": "Cart page" },
          { "value": "drawer", "label": "Drawer" }
        ],
        "default": "drawer"
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "Facebook URL"
      },
      {
        "type": "text",
        "id": "social_tiktok_link",
        "label": "TikTok URL"
      },
      {
        "type": "text",
        "id": "social_pinterest_link",
        "label": "Pinterest URL"
      }
    ]
  }
]
