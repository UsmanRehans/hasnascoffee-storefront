<section class="featured-collection section-padding">
  <div class="container">

    <div class="section-header">
      {% if section.settings.eyebrow %}
        <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading %}
        <h2 class="section-heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading %}
        <p class="section-subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="collection-filter" role="tablist" aria-label="Filter products">
      <button class="filter-btn is-active" role="tab" data-filter="all">All</button>
      <button class="filter-btn" role="tab" data-filter="single-origin">Single Origin</button>
      <button class="filter-btn" role="tab" data-filter="blend">Blends</button>
      <button class="filter-btn" role="tab" data-filter="espresso">Espresso</button>
    </div>

    {% assign collection = collections[section.settings.collection] %}
    {% if collection %}
      <div class="products-grid" id="FeaturedProducts">
        {% for product in collection.products limit: section.settings.products_to_show %}
          {% render 'product-card', product: product %}
        {% endfor %}
      </div>

      {% if section.settings.show_view_all %}
        <div class="section-cta">
          <a href="{{ collection.url }}" class="btn btn--outline">
            View All {{ collection.title }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      {% endif %}
    {% else %}
      <div class="products-grid">
        {% for i in (1..4) %}
          <div class="product-card product-card--placeholder">
            <div class="product-card__image-wrap">
              {{ 'product-' | append: i | placeholder_svg_tag: 'product-card__placeholder-svg' }}
            </div>
            <div class="product-card__info">
              <h3 class="product-card__title">Sample Coffee {{ i }}</h3>
              <p class="product-card__origin">Ethiopia · Light Roast</p>
              <p class="product-card__price">$18.00</p>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Our Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Crafted for Coffee Lovers"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "From bright and fruity to rich and bold — explore coffees that match your taste."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
