<footer class="site-footer">
  <div class="footer__top">
    <div class="container">
      <div class="footer__grid">

        <div class="footer__brand">
          <a href="{{ routes.root_url }}" class="footer__logo-wrap">
            <img src="{{ 'Hasna-Logo-No-Text.png' | asset_url }}" alt="{{ shop.name }}" class="footer__logo-icon" loading="lazy">
            <img src="{{ 'Hasna-Logo-Text.png' | asset_url }}" alt="{{ shop.name }}" class="footer__logo-text-img" loading="lazy">
          </a>
          <p class="footer__tagline">{{ section.settings.tagline | default: 'Ethiopian coffee, roasted in Austin. Sourced with love, served with purpose.' }}</p>

          <div class="footer__social">
            <a href="https://www.instagram.com/hasnasethiopiancoffeehouse" target="_blank" rel="noopener" aria-label="Follow us on Instagram" class="footer__social-link">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
              <span>@hasnasethiopiancoffeehouse</span>
            </a>
          </div>
        </div>

        <div class="footer__column">
          <h4 class="footer__column-heading">Shop</h4>
          <ul class="footer__nav-list">
            {% for link in linklists['footer-shop'].links %}
              <li><a href="{{ link.url }}" class="footer__nav-link">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </div>

        <div class="footer__column">
          <h4 class="footer__column-heading">Company</h4>
          <ul class="footer__nav-list">
            {% for link in linklists['footer-info'].links %}
              <li><a href="{{ link.url }}" class="footer__nav-link">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </div>

        <div class="footer__contact">
          <h4 class="footer__column-heading">Contact</h4>
          <a href="mailto:hasnascoffee@gmail.com" class="footer__contact-link">hasnascoffee@gmail.com</a>
          <p class="footer__address">North Austin, Texas</p>
        </div>

      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container">
      <p class="footer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <div class="footer__legal">
        {% if linklists['footer'].links.size > 0 %}
          {% for link in linklists['footer'].links %}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        {% endif %}
      </div>
      {% unless shop.enabled_payment_types == empty %}
        <div class="footer__payment">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag: class: 'payment-icon' }}
          {% endfor %}
        </div>
      {% endunless %}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Exceptional coffee, ethically sourced and freshly roasted."
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Contact email"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Contact phone"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Navigation column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Navigation menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
