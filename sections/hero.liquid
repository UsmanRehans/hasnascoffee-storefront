<section class="hero-card" id="Hero">
  <div class="hero-card__inner">
    {% if section.settings.background_image %}
      <img
        src="{{ section.settings.background_image | img_url: '2000x' }}"
        srcset="{{ section.settings.background_image | img_url: '800x' }} 800w,
                {{ section.settings.background_image | img_url: '1400x' }} 1400w,
                {{ section.settings.background_image | img_url: '2000x' }} 2000w"
        sizes="(max-width: 900px) 100vw, 90vw"
        alt="{{ section.settings.background_image.alt | escape }}"
        loading="eager"
        fetchpriority="high"
        class="hero-card__image"
      >
    {% else %}
      <div class="hero-card__image hero-card__image--placeholder"></div>
    {% endif %}

    <div class="hero-card__overlay"></div>

    <div class="hero-card__content">
      {% if section.settings.eyebrow %}
        <p class="hero-card__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading %}
        <h1 class="hero-card__heading">{{ section.settings.heading }}</h1>
      {% endif %}

      <div class="hero-card__actions">
        {% if section.settings.button_label %}
          <a href="{{ section.settings.button_link }}" class="hero-card__btn">
            {{ section.settings.button_label }}
          </a>
        {% endif %}
        {% if section.settings.secondary_button_label %}
          <a href="{{ section.settings.secondary_button_link }}" class="hero-card__btn hero-card__btn--ghost">
            {{ section.settings.secondary_button_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Roasted in Austin · Sourced from Ethiopia" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Brewed Fresh,\nServed Warm." },
    { "type": "text", "id": "button_label", "label": "Primary button", "default": "Shop Coffee" },
    { "type": "url", "id": "button_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_button_label", "label": "Secondary button" },
    { "type": "url", "id": "secondary_button_link", "label": "Secondary button link" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
