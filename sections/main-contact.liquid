<section class="contact-page section-padding">
  <div class="container container--narrow">

    <div class="contact-page__header">
      <p class="section-eyebrow">Get in Touch</p>
      <h1 class="section-heading">Contact Us</h1>
      <p class="contact-page__subtitle">We'd love to hear from you. Choose how we can help below.</p>
    </div>

    <div class="contact-tabs">
      <div class="contact-tabs__nav" role="tablist">
        <button class="contact-tab-btn contact-tab-btn--active" role="tab" aria-selected="true" aria-controls="tab-bookings" data-tab="bookings">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Event Bookings
        </button>
        <button class="contact-tab-btn" role="tab" aria-selected="false" aria-controls="tab-customer-service" data-tab="customer-service">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Customer Service
        </button>
      </div>

      {%- comment -%} EVENT BOOKINGS TAB {%- endcomment -%}
      <div class="contact-tab-panel contact-tab-panel--active" id="tab-bookings" role="tabpanel">
        <div class="contact-tab-panel__intro">
          <h2>Book Us for Your Event</h2>
          <p>Sister Hasna and her team are available to bring the Hasna's Coffee experience to your event — from community gatherings and corporate functions to weddings, celebrations, and private pop-ups. Fill out the form below and we'll be in touch within 48 hours.</p>
        </div>
        <form class="contact-form" action="https://formsubmit.co/hasnascoffee@gmail.com" method="POST">
          <input type="hidden" name="_subject" value="Event Booking Inquiry - Hasna's Coffee">
          <input type="hidden" name="_next" value="{{ shop.url }}/pages/contact?submitted=true">
          <input type="hidden" name="_captcha" value="false">

          <div class="contact-form__row">
            <div class="contact-form__field">
              <label for="booking-name">Full Name <span>*</span></label>
              <input type="text" id="booking-name" name="name" required placeholder="Your full name">
            </div>
            <div class="contact-form__field">
              <label for="booking-email">Email Address <span>*</span></label>
              <input type="email" id="booking-email" name="email" required placeholder="your@email.com">
            </div>
          </div>

          <div class="contact-form__row">
            <div class="contact-form__field">
              <label for="booking-phone">Phone Number</label>
              <input type="tel" id="booking-phone" name="phone" placeholder="(555) 000-0000">
            </div>
            <div class="contact-form__field">
              <label for="booking-date">Event Date <span>*</span></label>
              <input type="date" id="booking-date" name="event_date" required>
            </div>
          </div>

          <div class="contact-form__row">
            <div class="contact-form__field">
              <label for="booking-type">Event Type <span>*</span></label>
              <select id="booking-type" name="event_type" required>
                <option value="" disabled selected>Select event type</option>
                <option>Corporate Event</option>
                <option>Wedding / Celebration</option>
                <option>Community Gathering</option>
                <option>Private Pop-Up</option>
                <option>Fundraiser</option>
                <option>Other</option>
              </select>
            </div>
            <div class="contact-form__field">
              <label for="booking-guests">Expected Guest Count</label>
              <input type="number" id="booking-guests" name="guest_count" placeholder="Approx. number of guests" min="1">
            </div>
          </div>

          <div class="contact-form__field">
            <label for="booking-location">Event Location / Venue</label>
            <input type="text" id="booking-location" name="location" placeholder="Address or venue name">
          </div>

          <div class="contact-form__field">
            <label for="booking-message">Tell Us More</label>
            <textarea id="booking-message" name="message" rows="4" placeholder="Any special requests, themes, or details about your event..."></textarea>
          </div>

          <button type="submit" class="btn btn--primary contact-form__submit">Send Booking Request</button>
        </form>
      </div>

      {%- comment -%} CUSTOMER SERVICE TAB {%- endcomment -%}
      <div class="contact-tab-panel" id="tab-customer-service" role="tabpanel">
        <div class="contact-tab-panel__intro">
          <h2>Customer Service</h2>
          <p>Have a question about your order, our products, or anything else? We're here to help. Reach out and we'll get back to you as soon as possible — usually within 1 business day.</p>
          <div class="contact-direct">
            <a href="mailto:hasnascoffee@gmail.com" class="contact-direct__link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              hasnascoffee@gmail.com
            </a>
          </div>
        </div>
        <form class="contact-form" action="https://formsubmit.co/hasnascoffee@gmail.com" method="POST">
          <input type="hidden" name="_subject" value="Customer Service - Hasna's Coffee">
          <input type="hidden" name="_next" value="{{ shop.url }}/pages/contact?submitted=true">
          <input type="hidden" name="_captcha" value="false">

          <div class="contact-form__row">
            <div class="contact-form__field">
              <label for="cs-name">Full Name <span>*</span></label>
              <input type="text" id="cs-name" name="name" required placeholder="Your full name">
            </div>
            <div class="contact-form__field">
              <label for="cs-email">Email Address <span>*</span></label>
              <input type="email" id="cs-email" name="email" required placeholder="your@email.com">
            </div>
          </div>

          <div class="contact-form__field">
            <label for="cs-order">Order Number (if applicable)</label>
            <input type="text" id="cs-order" name="order_number" placeholder="#1001">
          </div>

          <div class="contact-form__field">
            <label for="cs-subject">Subject <span>*</span></label>
            <select id="cs-subject" name="subject" required>
              <option value="" disabled selected>What can we help with?</option>
              <option>Order Status / Tracking</option>
              <option>Returns & Refunds</option>
              <option>Product Question</option>
              <option>Subscription</option>
              <option>Something Else</option>
            </select>
          </div>

          <div class="contact-form__field">
            <label for="cs-message">Message <span>*</span></label>
            <textarea id="cs-message" name="message" rows="5" required placeholder="How can we help you today?"></textarea>
          </div>

          <button type="submit" class="btn btn--primary contact-form__submit">Send Message</button>
        </form>
      </div>

    </div>
  </div>
</section>

{% if request.path contains 'contact' %}
  {% if request.query_string contains 'submitted=true' %}
    <div class="contact-success" id="ContactSuccess">
      <div class="container container--narrow">
        <div class="contact-success__inner">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <h3>Message Sent!</h3>
          <p>Thank you for reaching out. We'll get back to you within 1–2 business days.</p>
        </div>
      </div>
    </div>
  {% endif %}
{% endif %}

<script>
  document.querySelectorAll('.contact-tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = this.getAttribute('data-tab');
      document.querySelectorAll('.contact-tab-btn').forEach(function(b) {
        b.classList.remove('contact-tab-btn--active');
        b.setAttribute('aria-selected', 'false');
      });
      document.querySelectorAll('.contact-tab-panel').forEach(function(p) {
        p.classList.remove('contact-tab-panel--active');
      });
      this.classList.add('contact-tab-btn--active');
      this.setAttribute('aria-selected', 'true');
      document.getElementById('tab-' + tab).classList.add('contact-tab-panel--active');
    });
  });
</script>

{% schema %}
{
  "name": "Contact Page",
  "tag": "section",
  "settings": []
}
{% endschema %}
