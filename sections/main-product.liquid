<section class="product-page section-padding">
  <div class="container">
    <div class="product-page__grid">

      <!-- Media Gallery -->
      <div class="product-gallery">
        <div class="product-gallery__main" id="ProductGalleryMain">
          {% if product.images.size > 0 %}
            {% for image in product.images %}
              <div class="product-gallery__slide {% if forloop.first %}is-active{% endif %}" data-slide="{{ forloop.index0 }}">
                <img
                  src="{{ image | img_url: '1200x' }}"
                  alt="{{ image.alt | escape | default: product.title }}"
                  {% if forloop.first %}loading="eager"{% else %}loading="lazy"{% endif %}
                  class="product-gallery__image"
                >
              </div>
            {% endfor %}
          {% else %}
            <div class="product-gallery__slide is-active">
              {{ 'product-1' | placeholder_svg_tag: 'product-gallery__placeholder' }}
            </div>
          {% endif %}
        </div>

        {% if product.images.size > 1 %}
          <div class="product-gallery__thumbs" id="ProductGalleryThumbs">
            {% for image in product.images %}
              <button
                class="product-gallery__thumb {% if forloop.first %}is-active{% endif %}"
                data-thumb="{{ forloop.index0 }}"
                aria-label="View image {{ forloop.index }}"
              >
                <img
                  src="{{ image | img_url: '150x150', crop: 'center' }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                >
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- Product Info -->
      <div class="product-info">
        {% if product.vendor %}
          <p class="product-info__vendor">{{ product.vendor }}</p>
        {% endif %}

        <h1 class="product-info__title">{{ product.title }}</h1>

        <div class="product-info__price-wrap">
          <span class="product-info__price" id="ProductPrice">{{ product.price | money }}</span>
          {% if product.compare_at_price > product.price %}
            <span class="product-info__compare-price">{{ product.compare_at_price | money }}</span>
            <span class="product-info__badge">Save {{ product.price | minus: product.compare_at_price | abs | money }}</span>
          {% endif %}
        </div>

        {% form 'product', product, id: 'ProductForm', novalidate: 'novalidate' %}
          {% unless product.has_only_default_variant %}
            {% for option in product.options_with_values %}
              <div class="product-option">
                <label class="product-option__label">{{ option.name }}</label>
                <div class="product-option__values">
                  {% for value in option.values %}
                    <button
                      type="button"
                      class="product-option__value {% if option.selected_value == value %}is-active{% endif %}"
                      data-option="{{ option.position }}"
                      data-value="{{ value | escape }}"
                    >
                      {{ value }}
                    </button>
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          {% endunless %}

          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" id="ProductVariantId">

          <div class="product-info__quantity">
            <label for="ProductQuantity" class="product-option__label">Quantity</label>
            <div class="quantity-selector">
              <button type="button" class="quantity-selector__btn" data-action="decrease" aria-label="Decrease quantity">−</button>
              <input
                type="number"
                id="ProductQuantity"
                name="quantity"
                value="1"
                min="1"
                class="quantity-selector__input"
                aria-label="Quantity"
              >
              <button type="button" class="quantity-selector__btn" data-action="increase" aria-label="Increase quantity">+</button>
            </div>
          </div>

          <div class="product-info__actions">
            {% if product.available %}
              <button type="submit" name="add" class="btn btn--primary btn--large product-info__atc" id="AddToCartBtn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/>
                </svg>
                Add to Cart
              </button>
              <button type="button" class="btn btn--outline btn--large" onclick="this.closest('form').submit()">
                Buy it now
              </button>
            {% else %}
              <button type="button" class="btn btn--primary btn--large" disabled>Sold Out</button>
            {% endif %}
          </div>
        {% endform %}

        {% if product.description != blank %}
          <div class="product-info__description">
            <details class="product-accordion" open>
              <summary class="product-accordion__header">
                <span>Description</span>
                <svg class="product-accordion__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 9l6 6 6-6"/>
                </svg>
              </summary>
              <div class="product-accordion__body rte">
                {{ product.description }}
              </div>
            </details>
          </div>
        {% endif %}

        <div class="product-info__meta">
          {% if product.type != blank %}
            <p class="product-info__meta-item"><strong>Type:</strong> {{ product.type }}</p>
          {% endif %}
          {% if product.vendor != blank %}
            <p class="product-info__meta-item"><strong>Vendor:</strong> {{ product.vendor }}</p>
          {% endif %}
          {% if product.selected_or_first_available_variant.sku != blank %}
            <p class="product-info__meta-item"><strong>SKU:</strong> {{ product.selected_or_first_available_variant.sku }}</p>
          {% endif %}
        </div>

      </div>
    </div>
  </div>
</section>

<style>
.product-page__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-16);
  align-items: start;
}

.product-gallery__main {
  position: relative;
  border-radius: var(--radius-xl);
  overflow: hidden;
  background: var(--color-surface);
  aspect-ratio: 1;
}

.product-gallery__slide {
  display: none;
  width: 100%;
  height: 100%;
}

.product-gallery__slide.is-active { display: block; }

.product-gallery__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.product-gallery__thumbs {
  display: flex;
  gap: var(--space-2);
  margin-top: var(--space-3);
  overflow-x: auto;
  padding-bottom: var(--space-1);
}

.product-gallery__thumb {
  flex-shrink: 0;
  width: 72px;
  height: 72px;
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 2px solid transparent;
  transition: border-color var(--transition-fast);
  cursor: pointer;
}

.product-gallery__thumb img { width: 100%; height: 100%; object-fit: cover; }
.product-gallery__thumb.is-active,
.product-gallery__thumb:hover { border-color: var(--color-gold); }

.product-info__vendor {
  font-size: var(--text-xs);
  color: var(--color-gold);
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: var(--space-2);
}

.product-info__title {
  font-family: var(--font-display);
  font-size: clamp(var(--text-2xl), 3vw, var(--text-4xl));
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.2;
  margin-bottom: var(--space-4);
}

.product-info__price-wrap {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-bottom: var(--space-6);
}

.product-info__price {
  font-size: var(--text-2xl);
  font-weight: 700;
  color: var(--color-text);
}

.product-info__compare-price {
  font-size: var(--text-lg);
  color: var(--color-text-muted);
  text-decoration: line-through;
}

.product-info__badge {
  background: var(--color-gold);
  color: var(--color-bg);
  font-size: var(--text-xs);
  font-weight: 700;
  padding: 3px var(--space-3);
  border-radius: var(--radius-full);
}

.product-option { margin-bottom: var(--space-5); }

.product-option__label {
  display: block;
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: var(--space-3);
  letter-spacing: 0.03em;
}

.product-option__values { display: flex; flex-wrap: wrap; gap: var(--space-2); }

.product-option__value {
  padding: var(--space-2) var(--space-4);
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  background: transparent;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: all var(--transition-fast);
}

.product-option__value:hover { border-color: var(--color-gold); color: var(--color-gold); }
.product-option__value.is-active { background: var(--color-gold); border-color: var(--color-gold); color: var(--color-bg); font-weight: 600; }

.product-info__quantity { margin-bottom: var(--space-6); }

.quantity-selector {
  display: flex;
  align-items: center;
  gap: 0;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
  width: fit-content;
  margin-top: var(--space-3);
}

.quantity-selector__btn {
  width: 44px;
  height: 44px;
  font-size: var(--text-xl);
  color: var(--color-text-muted);
  background: var(--color-surface);
  border: none;
  cursor: pointer;
  transition: color var(--transition-fast);
}

.quantity-selector__btn:hover { color: var(--color-gold); }

.quantity-selector__input {
  width: 60px;
  height: 44px;
  text-align: center;
  background: transparent;
  border: none;
  border-left: 1px solid var(--color-border);
  border-right: 1px solid var(--color-border);
  color: var(--color-text);
  font-size: var(--text-base);
  font-weight: 600;
  outline: none;
  -moz-appearance: textfield;
}

.quantity-selector__input::-webkit-outer-spin-button,
.quantity-selector__input::-webkit-inner-spin-button { -webkit-appearance: none; }

.product-info__actions {
  display: flex;
  gap: var(--space-4);
  margin-bottom: var(--space-8);
}

.product-info__atc { flex: 1; justify-content: center; }

.product-accordion { border-top: 1px solid var(--color-border); padding-top: var(--space-5); margin-top: var(--space-6); }

.product-accordion__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  list-style: none;
  padding-bottom: var(--space-4);
}

.product-accordion__header::-webkit-details-marker { display: none; }

.product-accordion__icon { transition: transform var(--transition-base); }
details[open] .product-accordion__icon { transform: rotate(180deg); }

.product-accordion__body { padding-bottom: var(--space-5); }

.product-info__meta {
  border-top: 1px solid var(--color-border);
  padding-top: var(--space-5);
  margin-top: var(--space-4);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.product-info__meta-item {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
}

.product-info__meta-item strong { color: var(--color-text); }

@media (max-width: 768px) {
  .product-page__grid { grid-template-columns: 1fr; }
  .product-info__actions { flex-direction: column; }
  .product-info__atc { width: 100%; }
}
</style>

<script>
  // Gallery
  document.querySelectorAll('.product-gallery__thumb').forEach(thumb => {
    thumb.addEventListener('click', () => {
      const idx = thumb.dataset.thumb;
      document.querySelectorAll('.product-gallery__slide').forEach(s => s.classList.remove('is-active'));
      document.querySelectorAll('.product-gallery__thumb').forEach(t => t.classList.remove('is-active'));
      document.querySelector(`.product-gallery__slide[data-slide="${idx}"]`)?.classList.add('is-active');
      thumb.classList.add('is-active');
    });
  });

  // Quantity selector
  document.querySelectorAll('.quantity-selector__btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const input = btn.closest('.quantity-selector').querySelector('.quantity-selector__input');
      let val = parseInt(input.value) || 1;
      if (btn.dataset.action === 'increase') val++;
      else if (btn.dataset.action === 'decrease' && val > 1) val--;
      input.value = val;
    });
  });

  // Variant selection
  document.querySelectorAll('.product-option__value').forEach(btn => {
    btn.addEventListener('click', () => {
      const optionPosition = btn.dataset.option;
      btn.closest('.product-option__values').querySelectorAll('.product-option__value').forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
    });
  });
</script>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "settings": []
}
{% endschema %}
