{%- assign current_variant = product.selected_or_first_available_variant -%}

<nav class="product-breadcrumb" aria-label="Breadcrumb">
  <a href="{{ routes.root_url }}">Home</a>
  <span aria-hidden="true">›</span>
  {%- if collection -%}
    <a href="{{ collection.url }}">{{ collection.title }}</a>
    <span aria-hidden="true">›</span>
  {%- endif -%}
  <span aria-current="page">{{ product.title }}</span>
</nav>

<div class="product-layout">

  {%- comment -%} ── Gallery ── {%- endcomment -%}
  <div class="product-gallery">
    {%- if product.images.size > 1 -%}
      <div class="product-gallery__thumbs" id="hc-thumbs">
        {%- for image in product.images limit: 8 -%}
          <button
            class="product-gallery__thumb {% if forloop.first %}is-active{% endif %}"
            data-index="{{ forloop.index0 }}"
            aria-label="View image {{ forloop.index }}"
          >
            <img
              src="{{ image | image_url: width: 200 }}"
              alt="{{ image.alt | default: product.title | escape }}"
              width="100"
              height="100"
              loading="lazy"
            >
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="product-gallery__main" id="hc-main-image">
      {%- if product.featured_image -%}
        <img
          id="hc-active-image"
          src="{{ product.featured_image | image_url: width: 1000 }}"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          width="1000"
          height="1200"
          loading="eager"
        >
      {%- else -%}
        <div class="product-gallery__placeholder"></div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ── Product info ── {%- endcomment -%}
  <div class="product-info">

    <p class="product-info__vendor section-eyebrow">{{ product.vendor }}</p>

    <h1 class="product-info__title">{{ product.title }}</h1>

    {%- if product.description != blank -%}
      <div class="product-info__desc">{{ product.description }}</div>
    {%- endif -%}

    <p class="product-info__price" id="hc-price">
      <s class="product-info__compare" id="hc-compare-price" {% unless current_variant.compare_at_price > current_variant.price %}hidden{% endunless %}>{{ current_variant.compare_at_price | money }}</s>
      <span class="product-info__sale-badge" id="hc-sale-badge" {% unless current_variant.compare_at_price > current_variant.price %}hidden{% endunless %}>Sale</span>
      <span id="hc-price-value">{{ current_variant.price | money }} USD</span>
    </p>

    {%- unless product.has_only_default_variant -%}
      {%- for option in product.options_with_values -%}
        <div class="product-option">
          <p class="product-option__label">{{ option.name | upcase }}</p>
          {%- if option.values.size > 3 -%}
            <div class="product-option__select-wrap">
              <select class="product-option__select" data-option-index="{{ forloop.index0 }}" aria-label="{{ option.name }}">
                {%- for value in option.values -%}
                  <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                {%- endfor -%}
              </select>
              <svg class="product-option__select-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
          {%- else -%}
            <div class="product-option__buttons" data-option-index="{{ forloop.index0 }}">
              {%- for value in option.values -%}
                <button class="product-option__btn {% if option.selected_value == value %}is-selected{% endif %}" data-value="{{ value | escape }}" type="button">{{ value }}</button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- endunless -%}

    {%- form 'product', product, id: 'hc-product-form' -%}
      <input type="hidden" name="id" id="hc-variant-id" value="{{ current_variant.id }}">

      <div class="product-qty-section">
        <label class="product-qty-label" for="hc-quantity">QUANTITY</label>
        <div class="product-quantity">
          <button type="button" class="product-quantity__btn" id="hc-qty-dec" aria-label="Decrease">−</button>
          <input type="number" id="hc-quantity" name="quantity" value="1" min="1" class="product-quantity__input" aria-label="Quantity">
          <button type="button" class="product-quantity__btn" id="hc-qty-inc" aria-label="Increase">+</button>
        </div>
      </div>

      <button type="submit" class="product-atc-btn" id="hc-atc-btn" {% unless current_variant.available %}disabled{% endunless %}>
        {%- if current_variant.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
      </button>
    {%- endform -%}

    <ul class="product-trust">
      <li>
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Secure checkout
      </li>
      <li>
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        Free shipping over $50
      </li>
      <li>
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
        Easy returns
      </li>
    </ul>

    <details class="product-accordion">
      <summary class="product-accordion__trigger">
        Brew Notes
        <svg class="product-accordion__chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
      </summary>
      <div class="product-accordion__body">
        {%- if product.metafields.custom.brew_notes != blank -%}
          {{ product.metafields.custom.brew_notes }}
        {%- else -%}
          <p class="product-accordion__body--placeholder">Brewing guide and tasting notes will be added here.</p>
        {%- endif -%}
      </div>
    </details>

    <details class="product-accordion">
      <summary class="product-accordion__trigger">
        Origin & Process
        <svg class="product-accordion__chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
      </summary>
      <div class="product-accordion__body">
        {%- if product.metafields.custom.origin != blank -%}
          {{ product.metafields.custom.origin }}
        {%- else -%}
          <p class="product-accordion__body--placeholder">Origin and processing details will be added here.</p>
        {%- endif -%}
      </div>
    </details>

  </div>
</div>

<script>
(function () {
  var productJson  = {{ product.variants | json }};
  var selectedOpts = {{ current_variant.options | json }};

  function findVariant(opts) {
    return productJson.find(function(v) {
      return v.options.every(function(o, i) { return o === opts[i]; });
    });
  }

  function formatMoney(cents) { return '$' + (cents / 100).toFixed(2); }

  function updateVariant() {
    var variant = findVariant(selectedOpts);
    if (!variant) return;

    var priceEl = document.getElementById('hc-price-value');
    if (priceEl) priceEl.textContent = formatMoney(variant.price) + ' USD';

    var compareEl = document.getElementById('hc-compare-price');
    var badgeEl   = document.getElementById('hc-sale-badge');
    var onSale    = variant.compare_at_price && variant.compare_at_price > variant.price;
    if (compareEl) { compareEl.hidden = !onSale; if (onSale) compareEl.textContent = formatMoney(variant.compare_at_price); }
    if (badgeEl)   badgeEl.hidden = !onSale;

    var btn = document.getElementById('hc-atc-btn');
    if (btn) { btn.disabled = !variant.available; btn.textContent = variant.available ? 'Add to Cart' : 'Sold Out'; }

    var idInput = document.getElementById('hc-variant-id');
    if (idInput) idInput.value = variant.id;
    if (history.replaceState) history.replaceState(null, '', '?variant=' + variant.id);

    if (variant.featured_image) setMainImage(variant.featured_image.src);
  }

  document.querySelectorAll('.product-option__buttons').forEach(function(group) {
    var idx = parseInt(group.dataset.optionIndex, 10);
    group.querySelectorAll('.product-option__btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        group.querySelectorAll('.product-option__btn').forEach(function(b) { b.classList.remove('is-selected'); });
        btn.classList.add('is-selected');
        selectedOpts[idx] = btn.dataset.value;
        updateVariant();
      });
    });
  });

  document.querySelectorAll('.product-option__select').forEach(function(sel) {
    var idx = parseInt(sel.dataset.optionIndex, 10);
    sel.addEventListener('change', function() { selectedOpts[idx] = sel.value; updateVariant(); });
  });

  function setMainImage(src) {
    var mainImg = document.getElementById('hc-active-image');
    if (mainImg) mainImg.src = src.replace(/width=\d+/, 'width=1000');
  }

  document.querySelectorAll('.product-gallery__thumb').forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      document.querySelectorAll('.product-gallery__thumb').forEach(function(t) { t.classList.remove('is-active'); });
      thumb.classList.add('is-active');
      var img = thumb.querySelector('img');
      if (img) setMainImage(img.src);
    });
  });

  var qtyInput = document.getElementById('hc-quantity');
  var decBtn   = document.getElementById('hc-qty-dec');
  var incBtn   = document.getElementById('hc-qty-inc');
  if (decBtn) decBtn.addEventListener('click', function() { var v = parseInt(qtyInput.value,10); if (v>1) qtyInput.value=v-1; });
  if (incBtn) incBtn.addEventListener('click', function() { qtyInput.value=parseInt(qtyInput.value,10)+1; });
})();
</script>

{% schema %}
{
  "name": "Product",
  "settings": [],
  "disabled_on": { "groups": ["header", "footer"] }
}
{% endschema %}
