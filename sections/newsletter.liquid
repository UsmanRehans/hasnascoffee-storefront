<section class="newsletter section-padding newsletter--accent">
  <div class="container">
    <div class="newsletter__inner">
      <div class="newsletter__content">
        {% if section.settings.eyebrow %}
          <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading %}
          <h2 class="newsletter__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading %}
          <p class="newsletter__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>

      <div class="newsletter__form-wrap">
        {% form 'customer', id: 'NewsletterForm' %}
          {% if form.posted_successfully? %}
            <p class="newsletter__success">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              Thank you for subscribing!
            </p>
          {% else %}
            <div class="newsletter__input-group">
              <input
                type="email"
                name="contact[email]"
                id="NewsletterEmail"
                placeholder="{{ section.settings.placeholder }}"
                required
                autocorrect="off"
                autocapitalize="off"
                aria-label="Email address"
              >
              <button type="submit" class="btn btn--primary newsletter__submit">
                {{ section.settings.button_label }}
              </button>
            </div>
            {% if form.errors %}
              <p class="newsletter__error">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
            {% endif %}
          {% endif %}
        {% endform %}
        <p class="newsletter__disclaimer">{{ section.settings.disclaimer }}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Stay in the Loop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get Early Access to New Arrivals"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Be the first to know about new origins, seasonal releases, and exclusive offers."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Enter your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer text",
      "default": "No spam, ever. Unsubscribe anytime."
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
